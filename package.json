{
    "name": "next-portfolio-website",
    "version": "1.0.0",
    "private": true,
    "engines": {
        "node": "24.x"
    },
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "resume:build": "sh scripts/generate-resume.sh",
        "typecheck": "tsc --noEmit",
        "test": "vitest run tests/unit",
        "test:e2e": "playwright test",
        "test:e2e:portfolio": "playwright test tests/e2e/site.spec.ts --grep \"homepage renders|featured project links|case study .* renders|legacy routes redirect|contact API validates|resume PDF and OG image|long keycap legends\" --workers=2",
        "test:e2e:a11y": "playwright test tests/e2e/accessibility.spec.ts --workers=2",
        "test:e2e:performance": "playwright test tests/e2e/performance.spec.ts --workers=1",
        "test:performance-budget": "npm run build && node scripts/check-performance-budget.mjs",
        "test:e2e:rendering": "playwright test tests/e2e/site.spec.ts --grep \"headline|diagram card\" --workers=1",
        "test:e2e:render-engine": "playwright test tests/e2e/.cpu-render-audit.spec.ts tests/e2e/keycap-architecture.spec.ts --grep \"keycap|compositor|camera|CSS control|software backend\" --workers=1"
    },
    "dependencies": {
        "@vercel/analytics": "^2.0.1",
        "@vercel/og": "^0.11.1",
        "next": "^16.2.10",
        "react": "^19.2.7",
        "react-dom": "^19.2.7"
    },
    "overrides": {
        "postcss": "^8.5.10"
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.12.1",
        "@playwright/test": "^1.61.1",
        "@types/node": "^26.1.1",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "typescript": "^5.9.3",
        "vitest": "^4.1.10"
    }
}
